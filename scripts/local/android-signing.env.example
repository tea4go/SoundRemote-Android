# 将此文件复制为 scripts/local/android-signing.env，并填入本地密钥信息。
# 本文件由 scripts/macos/build_android_bymac.sh 以 source 方式引入。
# 请勿将真实的 android-signing.env 或任何密钥库密码提交到 git。

KEYSTORE_FILE_PASSWORD="你的密钥库密码"

# 可选覆盖项：
# BUILD_NUMBER=13
# VERSION_NUMBER="0.6.0"
# KEYSTORE_FILE_PATH="$HOME/keystore/soundremote-keystore.jks"
# KEYSTORE_FILE_ALIAS="soundremote"
